# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ember
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5433/ember

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=yoursecretkeyhere
RUN_MIGRATIONS_ON_STARTUP=false
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# SMTP (alerts placeholder)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=alerts@mailscope.local
